# Copy this file to `.env.local` and fill in real values (never commit .env.local).

# --- Auth (optional) ---
# If BOTH are unset the site stays open (no login gate).
# SITE_PASSWORD is the single password users type on /login.
SITE_PASSWORD=change-me
# Random secret stored in the session cookie. Generate with:  openssl rand -hex 24
AUTH_SECRET=generate-a-long-random-hex-string

# --- Vehicle identity (kept out of the public repo) ---
# Shown in the header. NEXT_PUBLIC_ so it's available in the client bundle.
NEXT_PUBLIC_VEHICLE_VIN=YOUR-VIN-HERE
NEXT_PUBLIC_VEHICLE_PLATE=PLATE
